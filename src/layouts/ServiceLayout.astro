---
interface Props {
  title: string;
  sections?: { id: string; title: string }[];
}

const { title, sections = [] } = Astro.props;
const hasToc = sections.length > 0;
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Literata:ital,opsz,wght@0,7..72,400;0,7..72,600;0,7..72,700;1,7..72,400;1,7..72,600&display=swap" rel="stylesheet" />
  </head>
  <body
    class="bg-white text-black font-serif text-liturgical antialiased min-h-screen"
  >
    <nav class="print:hidden bg-stone-50 border-b border-stone-200 px-4 py-3 sticky top-0 z-30">
      <div class="max-w-3xl mx-auto flex items-center justify-between lg:max-w-5xl">
        <a href="/" class="text-rubric font-semibold hover:underline">
          Slujbe
        </a>
        <div class="flex items-center gap-2">
          {hasToc && (
            <button
              id="toc-toggle"
              class="text-stone-500 hover:text-rubric text-sm px-3 py-1 border border-stone-300 rounded hover:border-rubric transition-colors flex items-center gap-1"
            >
              <span id="toc-icon" class="text-xs">&#9776;</span>
              <span class="hidden sm:inline">Cuprins</span>
            </button>
          )}
          <button
            onclick="window.print()"
            class="text-stone-500 hover:text-rubric text-sm px-3 py-1 border border-stone-300 rounded hover:border-rubric transition-colors"
          >
            Tipărește
          </button>
        </div>
      </div>
    </nav>

    {/* Mobile TOC — dropdown panel below nav */}
    {hasToc && (
      <div id="toc-mobile" class="hidden lg:hidden print:hidden bg-stone-50 border-b border-stone-200 px-4 py-4 sticky top-[49px] z-20 max-h-[60vh] overflow-y-auto">
        <ul class="space-y-1 text-sm columns-2 sm:columns-3">
          {sections.map((s) => (
            <li class="break-inside-avoid">
              <a
                href={`#${s.id}`}
                data-toc-link
                data-toc-mobile-link
                class="block py-1 px-2 text-stone-600 hover:text-rubric hover:bg-white rounded transition-colors truncate"
              >
                {s.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <div class="lg:max-w-5xl lg:mx-auto lg:flex lg:gap-8 print:block">
      {/* Desktop TOC — sidebar */}
      {hasToc && (
        <aside id="toc-sidebar" class="hidden lg:block print:hidden w-60 shrink-0 pt-8 pl-4 transition-all duration-200">
          <nav class="sticky top-[4.5rem]">
            <h2 class="text-xs font-bold uppercase tracking-wide text-stone-400 mb-3">Cuprins</h2>
            <ul class="space-y-1 text-sm max-h-[calc(100vh-6rem)] overflow-y-auto">
              {sections.map((s) => (
                <li>
                  <a
                    href={`#${s.id}`}
                    data-toc-link
                    data-toc-desktop-link
                    class="block py-0.5 px-2 text-stone-600 hover:text-rubric hover:bg-stone-50 rounded transition-colors truncate"
                  >
                    {s.title}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )}

      <main class="flex-1 max-w-3xl mx-auto px-4 py-8 print:py-2 print:px-0 print:max-w-none">
        <h1
          class="text-2xl sm:text-3xl font-bold text-center mb-8 print:mb-4 print:text-2xl"
        >
          {title}
        </h1>
        <slot />
      </main>
    </div>

    <style is:global>
      /* Rubric styling -- liturgical instructions in red */
      .rubric {
        color: #b91c1c;
        font-style: italic;
      }

      /* Dialogue cues (priest, deacon, choir) */
      .cue {
        color: #b91c1c;
        font-weight: 600;
        font-style: normal;
      }

      /* Emphasis for exclamations */
      .exclamation {
        font-weight: 700;
      }

      /* Rubric color utility for Tailwind */
      .text-rubric {
        color: #b91c1c;
      }
      .hover\:text-rubric:hover {
        color: #b91c1c;
      }
      .border-rubric {
        border-color: #b91c1c;
      }
      .hover\:border-rubric:hover {
        border-color: #b91c1c;
      }

      /* Active TOC link */
      .toc-active {
        color: #b91c1c !important;
        background-color: rgb(245 245 244);
        font-weight: 600;
      }

      /* Print-friendly rules */
      @media print {
        body {
          font-size: 11pt;
          line-height: 1.6;
        }

        nav,
        aside,
        .no-print {
          display: none !important;
        }

        main {
          max-width: 100% !important;
          padding: 0 !important;
          margin: 0 1cm !important;
        }

        h1 {
          font-size: 16pt !important;
          margin-bottom: 0.5cm !important;
        }

        @page {
          margin: 1.5cm;
          size: A4;
        }

        /* Avoid breaking inside paragraphs or prayer blocks */
        p,
        .prayer-block {
          orphans: 3;
          widows: 3;
          break-inside: avoid;
        }
      }
    </style>

    <script>
      // TOC toggle
      const toggle = document.getElementById('toc-toggle');
      const tocMobile = document.getElementById('toc-mobile');
      const tocSidebar = document.getElementById('toc-sidebar');
      const tocIcon = document.getElementById('toc-icon');

      if (toggle) {
        let desktopOpen = true;
        let mobileOpen = false;

        toggle.addEventListener('click', () => {
          const isLg = window.matchMedia('(min-width: 1024px)').matches;

          if (isLg) {
            desktopOpen = !desktopOpen;
            if (tocSidebar) {
              tocSidebar.classList.toggle('lg:block', desktopOpen);
              tocSidebar.classList.toggle('lg:hidden', !desktopOpen);
            }
            if (tocIcon) tocIcon.textContent = desktopOpen ? '\u2630' : '\u2630';
            toggle.setAttribute('aria-expanded', String(desktopOpen));
          } else {
            mobileOpen = !mobileOpen;
            if (tocMobile) {
              tocMobile.classList.toggle('hidden', !mobileOpen);
            }
            toggle.setAttribute('aria-expanded', String(mobileOpen));
          }
        });

        // Close mobile TOC when clicking a link
        if (tocMobile) {
          tocMobile.addEventListener('click', (e) => {
            if ((e.target as HTMLElement).closest('a')) {
              mobileOpen = false;
              tocMobile.classList.add('hidden');
              toggle.setAttribute('aria-expanded', 'false');
            }
          });
        }
      }

      // Active section tracking
      const links = document.querySelectorAll('[data-toc-link]');
      if (links.length > 0) {
        const sections = Array.from(links).map(link => {
          const id = link.getAttribute('href')!.slice(1);
          return { id, el: document.getElementById(id)!, link };
        }).filter(s => s.el);

        // Deduplicate sections by id (mobile + desktop have same ids)
        const uniqueIds = [...new Set(sections.map(s => s.id))];
        const sectionEls = uniqueIds.map(id => document.getElementById(id)!).filter(Boolean);

        let current = '';
        const observer = new IntersectionObserver((entries) => {
          const visible = entries.filter(e => e.isIntersecting);
          if (visible.length > 0) {
            visible.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
            const id = visible[0].target.id;
            if (id !== current) {
              current = id;
              links.forEach(l => l.classList.remove('toc-active'));
              document.querySelectorAll(`[data-toc-link][href="#${id}"]`).forEach(el => {
                el.classList.add('toc-active');
              });
            }
          }
        }, {
          rootMargin: '-80px 0px -60% 0px',
          threshold: 0
        });

        sectionEls.forEach(el => observer.observe(el));
      }
    </script>
  </body>
</html>
