---
interface Props {
  text: string;
  glasIndicator?: string;
  rubric?: string;
}

const { text, glasIndicator, rubric } = Astro.props;
---

<div class="mb-4 pl-4 border-l-2 border-stone-200">
  {glasIndicator && (
    <span class="inline-block text-xs font-semibold uppercase tracking-wide text-stone-400 bg-stone-50 rounded px-2 py-0.5 mb-1">
      {glasIndicator}
    </span>
  )}

  {rubric && (
    <p class="text-red-700 italic text-sm mb-1">{rubric}</p>
  )}

  <p class="leading-relaxed">{text}</p>
</div>
